# ─────────────────────────────────────────────
#  GovAI Backend — Environment Configuration
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/govai

# AWS Credentials (leave blank to use MOCK mode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3
S3_BUCKET_NAME=govai-call-audio

# Bedrock (Legacy)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Whisper (Local Transcription Server)
WHISPER_URL=http://localhost:8080

# Governance
CONFIDENCE_THRESHOLD=80
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Delivery system webhook (external)
DELIVERY_WEBHOOK_URL=http://localhost:4000/api/ingest

# MOCK MODE — set to true if no real AWS keys
USE_MOCK_AWS=false
USE_MOCK_OLLAMA=false
